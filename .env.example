# Kit (formerly ConvertKit) Newsletter Integration — API v4
# These are server-side secrets used by the Cloudflare Pages Function (functions/api/newsletter.ts).
# Set them in the Cloudflare Pages dashboard: Settings → Environment variables
#
# KIT_FORM_ID: Found in your Kit dashboard under Grow → Forms → select your form → Settings
# KIT_API_KEY: Found in Kit dashboard under Settings → Advanced → API (use a v4 key)
KIT_FORM_ID=your_form_id_here
KIT_API_KEY=your_api_key_here
