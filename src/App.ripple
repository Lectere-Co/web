		}
		
		@keyframes pulse {
			0%, 100% { opacity: 1; box-shadow: 0 0 20px rgba(235, 51, 110, 0.5); }
			50% { opacity: 0.7; box-shadow: 0 0 40px rgba(235, 51, 110, 0.8); }
		}
		
		.demo-tooltip {
			position: absolute;
			top: 2rem;
