component SocialImpact() {
	<section class="social-impact">
		<div class="container">
			<h2 class="section-title">{"The digital accessibility crisis."}</h2>
			
			<div class="impact-content">
				<p class="impact-text">
					{"Every day, millions of people are left behind by software that assumes everyone learns the same way. Broken onboarding experiences waste countless hours and exclude those who need technology most."}
				</p>
				<p class="impact-text">
					{"Lectere exists to make software accessible to everyone — regardless of age, technical skill, or learning style."}
				</p>
			</div>
		</div>
	</section>

	<style>
		.social-impact {
			padding: 8rem 2rem;
			background: linear-gradient(135deg, rgba(155, 39, 76, 0.1) 0%, rgba(235, 51, 110, 0.1) 100%);
			position: relative;
			overflow: hidden;
		}
		
		.social-impact::before {
			content: '';
			position: absolute;
			inset: 0;
			background: linear-gradient(45deg, transparent 30%, rgba(155, 39, 76, 0.05) 50%, transparent 70%);
			animation: shimmer 8s ease-in-out infinite;
		}
		
		@keyframes shimmer {
			0%, 100% { transform: translateX(-100%); }
			50% { transform: translateX(100%); }
		}
		
		.impact-content {
			max-width: 800px;
			margin: 0 auto;
			position: relative;
			z-index: 1;
		}
		
		.impact-text {
			font-size: 1.4rem;
			line-height: 1.8;
			margin-bottom: 2rem;
			color: #e0e0e0;
			text-align: center;
		}
	</style>
}

component PricingSection() {
	<section class="pricing">
		<div class="container">
			<h2 class="section-title">{"Simple pricing."}</h2>
			
			<div class="pricing-grid">
				<div class="pricing-card">
					<h3>{"Essential"}</h3>
					<div class="price">
						<span class="amount">{"$12"}</span>
						<span class="period">{"/month"}</span>
					</div>
					<div class="price-alt">{"or $99/year"}</div>
					<ul class="features-list">
						<li>{"Up to 100 guided workflows"}</li>
						<li>{"Basic analytics"}</li>
						<li>{"Email support"}</li>
					</ul>
					<button class="btn-primary">{"Get Started"}</button>
				</div>
				
				<div class="pricing-card featured">
					<div class="badge">{"MOST POPULAR"}</div>
					<h3>{"Professional"}</h3>
					<div class="price">
						<span class="amount">{"$39"}</span>
						<span class="period">{"/month per user"}</span>
					</div>
					<div class="price-alt">{" "}</div>
					<ul class="features-list">
						<li>{"Unlimited workflows"}</li>
						<li>{"Advanced analytics"}</li>
						<li>{"Priority support"}</li>
						<li>{"Custom integrations"}</li>
					</ul>
					<button class="btn-primary">{"Start Free Trial"}</button>
				</div>
			</div>
		</div>
	</section>

	<style>
		.pricing {
			padding: 8rem 2rem;
			background: linear-gradient(180deg, #1a1520 0%, #15111a 100%);
		}
		
		.pricing-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
			gap: 2rem;
			max-width: 900px;
			margin: 0 auto;
		}
		
		.pricing-card {
			background: rgba(255, 255, 255, 0.03);
			border: 1px solid rgba(155, 39, 76, 0.3);
			border-radius: 24px;
			padding: 3rem 2rem;
			text-align: center;
			transition: all 0.3s ease;
			position: relative;
		}
		
		.pricing-card.featured {
			border-color: var(--razzmatazz);
			border-width: 2px;
			box-shadow: 0 0 40px rgba(235, 51, 110, 0.3);
			transform: scale(1.05);
		}
		
		.pricing-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 12px 50px rgba(235, 51, 110, 0.3);
		}
		
		.pricing-card.featured:hover {
			transform: scale(1.05) translateY(-5px);
		}
		
		.badge {
			position: absolute;
			top: -15px;
			left: 50%;
			transform: translateX(-50%);
			background: linear-gradient(135deg, var(--razzmatazz), var(--amaranth-purple));
			padding: 0.5rem 1.5rem;
			border-radius: 20px;
			font-size: 0.8rem;
			font-weight: 700;
			letter-spacing: 0.05em;
		}
		
		.pricing-card h3 {
			font-size: 1.8rem;
			margin-bottom: 1.5rem;
		}
		
		.price {
			margin-bottom: 0.5rem;
		}
		
		.amount {
			font-size: 3.5rem;
			font-weight: 800;
			background: linear-gradient(135deg, var(--razzmatazz), var(--amaranth-purple));
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
		}
		
		.period {
			font-size: 1rem;
			color: #888;
		}
		
		.price-alt {
			color: #888;
			margin-bottom: 2rem;
			min-height: 1.5rem;
		}
		
		.features-list {
			list-style: none;
			margin: 2rem 0;
			text-align: left;
		}
		
		.features-list li {
			padding: 0.75rem 0;
			color: #d0d0d0;
			border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		}
		
		.features-list li::before {
			content: '✓ ';
			color: var(--razzmatazz);
			font-weight: bold;
			margin-right: 0.5rem;
		}
		
		.pricing-card button {
			width: 100%;
			margin-top: 1.5rem;
		}
	</style>
}

