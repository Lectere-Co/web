import { track } from 'ripple';

export component App() {
	let mouseX = track(0);
	let mouseY = track(0);
	
	// Track mouse position for cursor-reactive effects
	const handleMouseMove = (e: MouseEvent) => {
		@mouseX = e.clientX;
		@mouseY = e.clientY;
	};
	
	<div class="app" onMouseMove={handleMouseMove}>
		<HeroSection mouseX={@mouseX} mouseY={@mouseY} />
		<ProblemSection />
		<WhatIsLectere />
		<HowItWorks />
		<ProductDemo />
		<WhoItsFor />
		<BusinessUseCases />
		<CompetitiveComparison />
		<SocialImpact />
		<PricingSection />
		<Testimonials />
		<FinalCTA />
		<Footer />
	</div>

	<style>
		.app {
			width: 100%;
			min-height: 100vh;
			background: #0a0a0f;
			color: #ffffff;
			overflow-x: hidden;
		}
	</style>
}

component HeroSection(props: { mouseX: number, mouseY: number }) {
	<section class="hero">
		<div class="hero-bg" style={`--mouse-x: ${props.mouseX}px; --mouse-y: ${props.mouseY}px;`}>
			<div class="cursor-glow"></div>
		</div>
		<div class="hero-content">
			<h1 class="hero-headline">{"Software that teaches you while you use it."}</h1>
			<p class="hero-subtext">
				{"Lectere is an AI assistant that lives inside software and shows you exactly what to click, step by step, in real time."}
			</p>
			<div class="hero-ctas">
				<button class="btn-primary">{"Watch Live Demo"}</button>
				<button class="btn-secondary">{"Get Started"}</button>
			</div>
		</div>
	</section>

	<style>
		.hero {
			position: relative;
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			overflow: hidden;
		}
		
		.hero-bg {
			position: absolute;
			inset: 0;
			background: radial-gradient(circle at 20% 30%, rgba(155, 39, 76, 0.15) 0%, transparent 50%),
			            radial-gradient(circle at 80% 70%, rgba(235, 51, 110, 0.15) 0%, transparent 50%),
			            linear-gradient(180deg, #0a0a0f 0%, #15111a 100%);
			animation: gradientShift 10s ease infinite;
		}
		
		.cursor-glow {
			position: absolute;
			width: 300px;
			height: 300px;
			border-radius: 50%;
			background: radial-gradient(circle, rgba(235, 51, 110, 0.2) 0%, transparent 70%);
			pointer-events: none;
			transform: translate(-50%, -50%);
			left: var(--mouse-x);
			top: var(--mouse-y);
			transition: opacity 0.3s ease;
		}
		
		@keyframes gradientShift {
			0%, 100% { filter: hue-rotate(0deg); }
			50% { filter: hue-rotate(10deg); }
		}
		
		.hero-content {
			position: relative;
			z-index: 1;
			max-width: 900px;
			padding: 2rem;
			text-align: center;
		}
		
		.hero-headline {
			font-size: clamp(2.5rem, 8vw, 5rem);
			font-weight: 800;
			letter-spacing: -0.03em;
			line-height: 1.1;
			margin-bottom: 1.5rem;
			background: linear-gradient(135deg, #ffffff 0%, #e0e0e0 100%);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
			animation: fadeInUp 1s ease-out;
		}
		
		@keyframes fadeInUp {
			from {
				opacity: 0;
				transform: translateY(30px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
		
		.hero-subtext {
			font-size: clamp(1.1rem, 2.5vw, 1.4rem);
			line-height: 1.6;
			color: #b0b0b0;
			margin-bottom: 3rem;
			max-width: 700px;
			margin-left: auto;
			margin-right: auto;
			animation: fadeInUp 1s ease-out 0.2s backwards;
		}
		
		.hero-ctas {
			display: flex;
			gap: 1rem;
			justify-content: center;
			flex-wrap: wrap;
			animation: fadeInUp 1s ease-out 0.4s backwards;
		}
		
		.btn-primary {
			background: var(--razzmatazz);
			color: white;
			padding: 1rem 2.5rem;
			font-size: 1.1rem;
			font-weight: 600;
			border: none;
			border-radius: 16px;
			cursor: pointer;
			transition: all 0.3s ease;
			box-shadow: 0 4px 20px rgba(235, 51, 110, 0.3);
		}
		
		.btn-primary:hover {
			transform: translateY(-2px) scale(1.02);
			box-shadow: 0 6px 30px rgba(235, 51, 110, 0.5);
		}
		
		.btn-secondary {
			background: transparent;
			color: white;
			padding: 1rem 2.5rem;
			font-size: 1.1rem;
			font-weight: 600;
			border: 2px solid var(--amaranth-purple);
			border-radius: 16px;
			cursor: pointer;
			transition: all 0.3s ease;
		}
		
		.btn-secondary:hover {
			transform: translateY(-2px);
			background: rgba(155, 39, 76, 0.1);
			box-shadow: 0 0 20px rgba(155, 39, 76, 0.3);
		}
	</style>
}

component ProblemSection() {
	<section class="problem">
		<div class="container">
			<h2 class="section-title">{"Software shouldn't be this hard."}</h2>
			
			<div class="stats-grid">
				<div class="stat-card">
					<div class="stat-number">{"76%"}</div>
					<div class="stat-label">{"of users give up when stuck"}</div>
				</div>
				<div class="stat-card">
					<div class="stat-number">{"Days or Weeks"}</div>
					<div class="stat-label">{"Onboarding takes"}</div>
				</div>
				<div class="stat-card">
					<div class="stat-number">{"$8.5T"}</div>
					<div class="stat-label">{"lost globally by 2030"}</div>
				</div>
			</div>
			
			<div class="frustration-flow">
				<div class="flow-step error">{"Wrong click"}</div>
				<div class="flow-arrow">{"→"}</div>
				<div class="flow-step error">{"Search help"}</div>
				<div class="flow-arrow">{"→"}</div>
				<div class="flow-step error">{"Watch outdated video"}</div>
				<div class="flow-arrow">{"→"}</div>
				<div class="flow-step error">{"Still stuck"}</div>
				<div class="flow-arrow">{"→"}</div>
				<div class="flow-step highlight">{"Give up"}</div>
			</div>
		</div>
	</section>

	<style>
		.problem {
			padding: 8rem 2rem;
			background: linear-gradient(180deg, #15111a 0%, #1a1520 100%);
			position: relative;
		}
		
		.container {
			max-width: 1200px;
			margin: 0 auto;
		}
		
		.section-title {
			font-size: clamp(2rem, 6vw, 3.5rem);
			font-weight: 800;
			text-align: center;
			margin-bottom: 4rem;
			letter-spacing: -0.02em;
		}
		
		.stats-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			gap: 2rem;
			margin-bottom: 5rem;
		}
		
		.stat-card {
			background: rgba(255, 255, 255, 0.03);
			border: 1px solid rgba(155, 39, 76, 0.2);
			border-radius: 24px;
			padding: 3rem 2rem;
			text-align: center;
			backdrop-filter: blur(10px);
			transition: all 0.3s ease;
		}
		
		.stat-card:hover {
			transform: translateY(-5px);
			border-color: rgba(155, 39, 76, 0.5);
			box-shadow: 0 8px 40px rgba(155, 39, 76, 0.2);
		}
		
		.stat-number {
			font-size: clamp(2.5rem, 5vw, 4rem);
			font-weight: 800;
			background: linear-gradient(135deg, var(--razzmatazz), var(--amaranth-purple));
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
			margin-bottom: 1rem;
		}
		
		.stat-label {
			font-size: 1.1rem;
			color: #b0b0b0;
		}
		
		.frustration-flow {
			display: flex;
			align-items: center;
			justify-content: center;
			flex-wrap: wrap;
			gap: 1rem;
			padding: 2rem;
		}
		
		.flow-step {
			padding: 1rem 1.5rem;
			border-radius: 12px;
			font-weight: 600;
			font-size: 1rem;
		}
		
		.flow-step.error {
			background: rgba(155, 39, 76, 0.15);
			border: 1px solid var(--amaranth-purple);
			color: #ff8fa3;
		}
		
		.flow-step.highlight {
			background: rgba(235, 51, 110, 0.2);
			border: 2px solid var(--razzmatazz);
			color: var(--razzmatazz);
		}
		
		.flow-arrow {
			color: var(--razzmatazz);
			font-size: 1.5rem;
		}
	</style>
}

