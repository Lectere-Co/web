---
const footerLinks = {
  Product: [
    { name: 'Features', path: '/product' },
    { name: 'Pricing', path: '/pricing' },
  ],
  Company: [
    { name: 'About', path: '/about' },
    { name: 'Solutions', path: '/solutions' },
  ],
};

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-secondary/50">
  <div class="container px-6 py-16">
    <div class="grid lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="group flex items-center gap-2 mb-4">
          <img src="/lecterelogo.svg" alt="Lectere" class="h-8" />
        </a>
        <p class="text-muted-foreground mb-6 max-w-xs">
          Fighting digital displacement with AI-powered learning assistance.
          Built by students at Bellaire High School.
        </p>
        <p class="text-sm text-muted-foreground">
          A JA Social Innovation Challenge project
        </p>
      </div>

      <!-- Links -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h4 class="font-semibold text-foreground mb-4">{category}</h4>
          <ul class="space-y-3">
            {links.map((link) => (
              <li>
                <a
                  href={link.path}
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-border mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-muted-foreground">
        &copy; {currentYear} Lectere. All rights reserved.
      </p>
      <p class="text-sm text-muted-foreground flex items-center gap-2">
        Made with
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="hsl(341, 82%, 56%)" stroke="hsl(341, 82%, 56%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
        </svg>
        in Houston, TX
      </p>
    </div>
  </div>
</footer>
