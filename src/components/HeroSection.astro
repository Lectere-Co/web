---
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-background pt-20">
  <!-- Dynamic Background Pattern -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-background/50 to-background"></div>
    
    <!-- Animated Blobs -->
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary/20 rounded-full blur-[120px] animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-accent/20 rounded-full blur-[100px] animate-pulse-slow delay-1000"></div>
  </div>

  <div class="container relative z-10 px-6">
    <div class="flex flex-col items-center text-center max-w-5xl mx-auto">
      
      <!-- Announcement Badge -->
      <div class="reveal reveal-up mb-8" data-delay="1">
        <a href="#newsletter-signup" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 border border-primary/20 backdrop-blur-sm shadow-sm hover:bg-white/80 transition-colors group">
          <span class="flex h-2 w-2 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          <span class="text-sm font-medium text-foreground">Coming Soon for macOS</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary w-4 h-4 transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
      </div>

      <!-- Main Headline -->
      <h1 class="reveal reveal-up text-5xl md:text-7xl lg:text-8xl font-display font-medium leading-[1.1] tracking-tight mb-8 text-foreground" data-delay="2">
        Software that <br class="hidden md:block" />
        <span class="text-gradient italic relative inline-block">
          teaches you
          <svg class="absolute w-full h-3 -bottom-1 left-0 text-primary/30" viewBox="0 0 100 10" preserveAspectRatio="none">
            <path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="3" fill="none" />
          </svg>
        </span>
        while you use it.
      </h1>

      <!-- Subheadline -->
      <p class="reveal reveal-up text-xl md:text-2xl text-muted-foreground max-w-2xl mb-12 leading-relaxed" data-delay="3">
        Lectere lives inside your apps and shows you exactly what to click. No more tutorials, no more searching—just instant, on-screen guidance.
      </p>

      <!-- CTA Buttons -->
      <div class="reveal reveal-up flex flex-col sm:flex-row gap-4 mb-20" data-delay="4">
        <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-primary to-accent text-white font-medium shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
          See How It Works
        </a>
        <a href="#newsletter-signup" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-white border border-border text-foreground font-medium shadow-sm hover:bg-secondary/50 hover:border-primary/20 transition-all duration-300">
          Join the Waitlist
        </a>
      </div>

      <!-- Hero Visual: The "App Interface" -->
      <div class="reveal reveal-scale w-full max-w-5xl relative" data-delay="5">
        <!-- Main Window Container -->
        <div class="relative bg-white rounded-2xl border border-border/50 shadow-2xl overflow-hidden aspect-[16/10] md:aspect-[21/9]">
          
          <!-- Window Controls -->
          <div class="absolute top-0 left-0 right-0 h-10 bg-secondary/50 border-b border-border/50 flex items-center px-4 gap-2 z-20">
            <div class="w-3 h-3 rounded-full bg-red-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-400/80"></div>
          </div>

          <!-- App Mockup Content (Abstract Dashboard) -->
          <div class="absolute inset-0 pt-10 bg-secondary/20 p-6 flex gap-6">
            <!-- Sidebar -->
            <div class="w-64 hidden md:flex flex-col gap-4">
              <div class="h-8 w-32 bg-white rounded-lg shadow-sm"></div>
              <div class="h-4 w-24 bg-border/40 rounded mt-4"></div>
              <div class="h-4 w-20 bg-border/40 rounded"></div>
              <div class="h-4 w-28 bg-border/40 rounded"></div>
              
              <div class="h-4 w-24 bg-border/40 rounded mt-8"></div>
              <div class="h-4 w-20 bg-border/40 rounded"></div>
              <div class="h-4 w-28 bg-border/40 rounded"></div>
            </div>

            <!-- Main Content Area -->
            <div class="flex-1 flex flex-col gap-6">
              <!-- Header -->
              <div class="h-16 bg-white rounded-xl border border-border/40 shadow-sm flex items-center justify-between px-6">
                <div class="h-6 w-48 bg-border/40 rounded"></div>
                <div class="h-8 w-8 rounded-full bg-border/40"></div>
              </div>

              <!-- Grid Content -->
              <div class="grid grid-cols-3 gap-6 h-full">
                <div class="col-span-2 bg-white rounded-xl border border-border/40 shadow-sm p-4 relative overflow-hidden group">
                  <!-- Abstract Chart -->
                  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-primary/5 to-transparent"></div>
                  <div class="flex items-end justify-between h-full px-4 pb-4 gap-2">
                    <div class="w-full bg-primary/10 h-[40%] rounded-t-sm"></div>
                    <div class="w-full bg-primary/20 h-[70%] rounded-t-sm"></div>
                    <div class="w-full bg-primary/10 h-[50%] rounded-t-sm"></div>
                    <div class="w-full bg-primary/30 h-[85%] rounded-t-sm"></div>
                    <div class="w-full bg-primary/10 h-[60%] rounded-t-sm"></div>
                  </div>
                </div>
                <div class="bg-white rounded-xl border border-border/40 shadow-sm p-4">
                   <div class="h-full w-full bg-border/10 rounded-lg"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- LECTERE OVERLAYS (The Magic) -->
          
          <!-- Overlay 1: Cursor Guidance -->
          <div class="absolute top-[40%] left-[60%] z-30 flex items-center gap-3 animate-float">
            <!-- Cursor -->
            <svg class="w-8 h-8 text-primary drop-shadow-xl" viewBox="0 0 24 24" fill="currentColor" stroke="white" stroke-width="2">
              <path d="M5.5 3.21l10.8 5.4a.5.5 0 0 1 .15.82l-3.5 2.8a.5.5 0 0 0-.17.38l.4 4.4a.5.5 0 0 1-.92.35l-2.8-4.8a.5.5 0 0 0-.8-.12l-3.2 2.6a.5.5 0 0 1-.82-.38V3.7a.5.5 0 0 1 .86-.49z"/>
            </svg>
            
            <!-- Tooltip -->
            <div class="bg-foreground text-background px-4 py-2 rounded-lg shadow-xl text-sm font-medium border border-white/10 flex items-center gap-2">
              <span>Click to generate report</span>
              <kbd class="hidden md:inline-flex h-5 items-center gap-1 rounded border border-white/20 bg-white/10 px-1.5 font-mono text-[10px] font-medium opacity-100">
                <span class="text-xs">⌘</span>K
              </kbd>
            </div>
          </div>

          <!-- Overlay 2: Success Message -->
          <div class="absolute bottom-12 right-12 z-30 animate-float" style="animation-delay: 2s;">
            <div class="bg-white text-foreground px-4 py-3 rounded-xl shadow-xl border border-border flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-green-100 text-green-600 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div class="flex flex-col">
                <span class="text-xs text-muted-foreground font-medium uppercase tracking-wider">Lectere</span>
                <span class="text-sm font-semibold">Report exported successfully!</span>
              </div>
            </div>
          </div>

        </div>
        
        <!-- Glow Effect behind the window -->
        <div class="absolute -inset-4 bg-gradient-to-tr from-primary/20 to-accent/20 rounded-[2rem] blur-2xl -z-10 opacity-50"></div>
      </div>

    </div>
  </div>
</section>

<style>
  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.1); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
</style>
