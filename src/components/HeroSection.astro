---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-white">
  <!-- Subtle accent blobs -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full bg-[#eb336e]/5 blur-[120px] -translate-y-1/2 translate-x-1/4"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-[#9b274c]/5 blur-[100px] translate-y-1/3 -translate-x-1/4"></div>

  <div class="container relative z-10 px-6 pt-12 pb-32 md:pt-16 md:pb-40">
    <div class="flex flex-col items-center text-center max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="reveal reveal-up" data-delay="1">
        <div class="inline-flex items-center rounded-full border border-[#eb336e]/20 bg-[#eb336e]/10 text-[#eb336e] shadow-sm shadow-[#eb336e]/10 font-semibold mb-8 py-1.5 px-4 text-sm gap-2">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#eb336e] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#9b274c]"></span>
          </span>
          Coming Soon for macOS
        </div>
      </div>

      <!-- Logo -->
      <div class="reveal reveal-scale" data-delay="2">
        <img src="/lecterelogonotext.svg" alt="" class="h-16 mb-8" />
      </div>

      <!-- Headline -->
      <h1
        class="reveal reveal-up text-5xl md:text-6xl lg:text-7xl font-display font-medium leading-[1.1] tracking-tight mb-8 text-foreground"
        data-delay="3"
      >
        Software that
        <span class="italic text-gradient">teaches you</span>
        while you use it.
      </h1>

      <!-- Subtext -->
      <p
        class="reveal reveal-up text-lg md:text-xl text-muted-foreground max-w-2xl mb-12 leading-relaxed"
        data-delay="4"
      >
        Lectere is an AI-powered learning assistant that provides real-time,
        contextual guidance through visual overlays&mdash;showing you exactly what
        to click, step by step.
      </p>

      <!-- CTAs -->
      <div class="reveal reveal-up flex flex-col sm:flex-row gap-4" data-delay="5">
        <a
          href="/product"
          class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-gradient-to-r from-[#eb336e] to-[#9b274c] text-white shadow-lg shadow-[#eb336e]/20 hover:shadow-xl hover:shadow-[#eb336e]/25 hover:-translate-y-0.5 h-14 rounded-xl px-10 text-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
          See How It Works
        </a>
        <button
          type="button"
          id="hero-waitlist-btn"
          class="group inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-border bg-background text-foreground hover:bg-secondary hover:text-foreground h-14 rounded-xl px-10 text-lg"
        >
          Join the Waitlist
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </button>
      </div>

      <!-- Floating Cards -->
      <div class="relative w-full max-w-3xl mt-20">
        <div
          id="hero-card-left"
          class="hero-float-card absolute -left-4 md:left-0 top-0 bg-white rounded-xl p-4 flex items-center gap-3 shadow-lg border border-border"
        >
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-[#eb336e] to-[#9b274c] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="m4 4 7.07 17 2.51-7.39L21 11.07z"></path></svg>
          </div>
          <span class="text-sm font-medium text-foreground">Click &ldquo;File&rdquo; to continue</span>
        </div>

        <div
          id="hero-card-right"
          class="hero-float-card absolute -right-4 md:right-0 top-12 bg-white rounded-xl p-4 flex items-center gap-3 shadow-lg border border-border"
        >
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-[#c43278] to-[#832558] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg>
          </div>
          <span class="text-sm font-medium text-foreground">Great job! Next step...</span>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="reveal absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-muted-foreground" data-delay="8">
      <div class="hero-scroll-pill w-6 h-10 rounded-full border-2 border-border flex justify-center pt-2">
        <div class="hero-scroll-dot w-1.5 h-1.5 rounded-full bg-muted-foreground"></div>
      </div>
      <span class="text-xs uppercase tracking-widest">Scroll to explore</span>
    </div>
  </div>
</section>

<style>
  /* Floating cards — entrance animation */
  .hero-float-card {
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
                transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #hero-card-left {
    transform: translateX(-50px) rotate(-5deg);
    transition-delay: 0.5s;
  }
  #hero-card-left.visible {
    opacity: 1;
    transform: rotate(-3deg);
  }

  #hero-card-right {
    transform: translateX(50px) rotate(5deg);
    transition-delay: 0.6s;
  }
  #hero-card-right.visible {
    opacity: 1;
    transform: rotate(3deg);
  }

  /* Scroll indicator bounce */
  .hero-scroll-pill {
    animation: hero-pill-bounce 1.5s ease-in-out infinite;
  }
  .hero-scroll-dot {
    animation: hero-dot-bounce 1.5s ease-in-out infinite;
  }

  @keyframes hero-pill-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }
  @keyframes hero-dot-bounce {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(12px); opacity: 0.3; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-float-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .hero-scroll-pill,
    .hero-scroll-dot {
      animation: none;
    }
  }
</style>

<script>
  function initHero() {
    const cardLeft = document.getElementById('hero-card-left');
    const cardRight = document.getElementById('hero-card-right');
    const waitlistBtn = document.getElementById('hero-waitlist-btn');

    // Observe floating cards for reveal (they use custom classes, not .reveal)
    const cardObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            cardObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    if (cardLeft) cardObserver.observe(cardLeft);
    if (cardRight) cardObserver.observe(cardRight);

    // Scroll-based parallax for floating cards
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReducedMotion) {
      // After entrance transition completes, disable transform transitions for smooth parallax
      [cardLeft, cardRight].forEach((card) => {
        if (!card) return;
        card.addEventListener(
          'transitionend',
          (e: Event) => {
            if ((e as TransitionEvent).propertyName === 'transform') {
              card.style.transitionProperty = 'opacity';
            }
          },
          { once: true }
        );
      });

      let ticking = false;
      const handleScroll = () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            const y1 = Math.max(-30, -(scrollY / 500) * 30);
            const y2 = Math.max(-50, -(scrollY / 500) * 50);

            if (cardLeft) {
              cardLeft.style.transform = `rotate(-3deg) translateY(${y1}px)`;
            }
            if (cardRight) {
              cardRight.style.transform = `rotate(3deg) translateY(${y2}px)`;
            }

            ticking = false;
          });
          ticking = true;
        }
      };
      
      // Remove any existing listener before adding new one
      if ((window as Window & { __heroParallaxHandler?: () => void }).__heroParallaxHandler) {
        window.removeEventListener('scroll', (window as Window & { __heroParallaxHandler?: () => void }).__heroParallaxHandler);
      }
      
      window.addEventListener('scroll', handleScroll, { passive: true });
      (window as Window & { __heroParallaxHandler?: () => void }).__heroParallaxHandler = handleScroll;
    }

    // Waitlist button scrolls to newsletter section
    if (waitlistBtn) {
      waitlistBtn.addEventListener('click', () => {
        const el = document.getElementById('newsletter-signup');
        if (!el) return;

        const header = document.querySelector('header');
        const headerHeight = header instanceof HTMLElement ? header.offsetHeight : 0;
        const elementPosition = el.getBoundingClientRect().top + window.scrollY;
        const offsetPosition = elementPosition - headerHeight;

        const reduced = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
        if (reduced) {
          window.scrollTo(0, offsetPosition);
        } else {
          window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
        }
      });
    }
  }

  // Initialize on first load
  initHero();

  // Re-initialize after View Transitions swap
  document.addEventListener('astro:after-swap', initHero);
</script>
