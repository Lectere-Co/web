---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<div class:list={['relative w-full max-w-2xl mx-auto', className]}>
  <svg viewBox="0 0 640 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto drop-shadow-xl" role="img" aria-label="Illustration of Lectere guiding a user through software">
    <!-- Window frame -->
    <rect x="20" y="20" width="600" height="360" rx="12" fill="white" stroke="#e5e5e5" stroke-width="1.5"/>

    <!-- Title bar -->
    <rect x="20" y="20" width="600" height="40" rx="12" fill="#f5f5f5"/>
    <rect x="20" y="48" width="600" height="12" fill="#f5f5f5"/>

    <!-- macOS dots -->
    <circle cx="46" cy="40" r="6" fill="#ff5f57"/>
    <circle cx="66" cy="40" r="6" fill="#ffbd2e"/>
    <circle cx="86" cy="40" r="6" fill="#28ca41"/>

    <!-- Window title text -->
    <rect x="270" y="34" width="100" height="12" rx="2" fill="#d4d4d4"/>

    <!-- Sidebar -->
    <rect x="20" y="60" width="140" height="320" fill="#fafafa"/>
    <line x1="160" y1="60" x2="160" y2="380" stroke="#e5e5e5" stroke-width="1"/>

    <!-- Sidebar items -->
    <rect x="36" y="80" width="108" height="10" rx="2" fill="#e5e5e5"/>
    <rect x="36" y="104" width="88" height="10" rx="2" fill="#e5e5e5"/>
    <rect x="36" y="128" width="100" height="10" rx="2" fill="#e5e5e5"/>
    <rect x="36" y="152" width="72" height="10" rx="2" fill="#e5e5e5"/>
    <rect x="36" y="176" width="96" height="10" rx="2" fill="#e5e5e5"/>

    <!-- Main content area -->
    <rect x="180" y="80" width="320" height="16" rx="3" fill="#e5e5e5"/>
    <rect x="180" y="112" width="400" height="10" rx="2" fill="#f0f0f0"/>
    <rect x="180" y="132" width="380" height="10" rx="2" fill="#f0f0f0"/>
    <rect x="180" y="152" width="340" height="10" rx="2" fill="#f0f0f0"/>

    <!-- Button row -->
    <rect x="180" y="184" width="80" height="32" rx="6" fill="#f0f0f0"/>
    <rect x="272" y="184" width="80" height="32" rx="6" fill="#f0f0f0"/>

    <!-- THE HIGHLIGHTED ELEMENT (target button) -->
    <rect x="374" y="184" width="100" height="32" rx="6" fill="#fce4ec" class="lectere-target"/>
    <rect x="392" y="195" width="64" height="10" rx="2" fill="#eb336e" opacity="0.4"/>

    <!-- Pulsing highlight border -->
    <rect x="370" y="180" width="108" height="40" rx="8" fill="none" stroke="#eb336e" stroke-width="2.5" class="lectere-pulse"/>

    <!-- More content below -->
    <rect x="180" y="240" width="400" height="10" rx="2" fill="#f0f0f0"/>
    <rect x="180" y="260" width="360" height="10" rx="2" fill="#f0f0f0"/>
    <rect x="180" y="280" width="320" height="10" rx="2" fill="#f0f0f0"/>

    <!-- Cursor pointing at highlighted button -->
    <g class="lectere-cursor" transform="translate(440, 210)">
      <path d="M0 0 L0 18 L5 14 L9 22 L12 20.5 L8 13 L14 12 Z" fill="#1a1a1a" stroke="white" stroke-width="1"/>
    </g>
  </svg>

  <!-- Tooltip (positioned via CSS, floats) -->
  <div class="lectere-tooltip absolute right-4 bottom-16 sm:right-8 sm:bottom-20 md:right-12 md:bottom-24 bg-white rounded-xl px-4 py-3 shadow-lg border border-[#eb336e]/20 max-w-[200px]">
    <div class="flex items-center gap-2 mb-1">
      <div class="w-5 h-5 rounded bg-gradient-to-br from-[#eb336e] to-[#9b274c] flex items-center justify-center shrink-0">
        <svg viewBox="0 0 24 24" class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
      </div>
      <span class="text-xs font-semibold text-foreground">Lectere</span>
    </div>
    <p class="text-xs text-muted-foreground leading-relaxed">Click here to continue</p>
  </div>
</div>

<style>
  .lectere-pulse {
    animation: lecterePulse 2s ease-in-out infinite;
  }

  .lectere-tooltip {
    animation: lectereFloat 3s ease-in-out infinite;
  }

  .lectere-cursor {
    animation: lectereCursorBob 2s ease-in-out infinite;
  }

  @keyframes lecterePulse {
    0%, 100% { opacity: 1; stroke-width: 2.5; }
    50% { opacity: 0.5; stroke-width: 3.5; }
  }

  @keyframes lectereFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes lectereCursorBob {
    0%, 100% { transform: translate(440px, 210px); }
    50% { transform: translate(440px, 214px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lectere-pulse,
    .lectere-tooltip,
    .lectere-cursor {
      animation: none;
    }
  }
</style>
