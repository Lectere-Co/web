---
const steps = [
  {
    label: "AI sees your screen",
    delay: "1",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    label: "Guides every click",
    delay: "2",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.586 12.586 19 19"/><path d="M3.688 3.037a.497.497 0 0 0-.651.651l6.5 15.999a.501.501 0 0 0 .947-.062l2.68-6.186a.5.5 0 0 1 .233-.233l6.186-2.68a.501.501 0 0 0 .062-.947z"/></svg>`,
  },
  {
    label: "Auto-updates",
    delay: "3",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>`,
  },
];
---

<section class="bg-secondary/30 py-16">
  <div class="container">
    <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-6">
      {steps.map((step, i) => (
        <>
          {/* Step item */}
          <div
            class="reveal reveal-up flex flex-col items-center gap-3"
            data-delay={step.delay}
          >
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#eb336e] to-[#9b274c] flex items-center justify-center text-white shadow-md">
              <Fragment set:html={step.icon} />
            </div>
            <span class="text-sm font-medium text-foreground/80 text-center">
              {step.label}
            </span>
          </div>

          {/* Arrow connector (between items, hidden on mobile) */}
          {i < steps.length - 1 && (
            <div class="hidden md:flex items-center reveal reveal-scale" data-delay={String(i + 1)}>
              <svg
                width="32"
                height="16"
                viewBox="0 0 32 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="text-muted-foreground/40"
              >
                <path
                  d="M0 8h28m0 0-6-6m6 6-6 6"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</section>
