<section class="relative py-24 md:py-32 overflow-hidden">
  <div class="absolute top-0 right-1/4 w-[500px] h-[500px] rounded-full bg-[#eb336e]/5 blur-[120px] -translate-y-1/2"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="reveal reveal-up text-center max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#eb336e]/10 border border-[#eb336e]/20 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#eb336e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
        <span class="text-sm font-medium text-[#eb336e]">Pricing</span>
      </div>

      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold text-foreground mb-6">
        Simple, <span class="text-gradient">accessible</span> pricing
      </h1>

      <p class="text-xl md:text-2xl text-muted-foreground leading-relaxed">
        Designed to be affordable for everyone. No hidden fees, no
        complicated tiers—just straightforward pricing.
      </p>
    </div>
  </div>
</section>
