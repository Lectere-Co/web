---
const plans = [
  {
    name: 'Essential Access',
    tagline: 'Perfect for personal use',
    features: [
      'Guidance for up to 5 applications',
      'Real-time visual overlays',
      'Step-by-step instructions',
      'Progress tracking',
      'Email support',
    ],
    featured: false,
  },
  {
    name: 'Lectere Plus',
    tagline: 'Best value for power users',
    badge: 'RECOMMENDED',
    features: [
      'Unlimited applications',
      'All Essential features',
      'Team sharing & collaboration',
      'Priority support',
      'Early access to new features',
      'Custom workflow creation',
    ],
    featured: true,
  },
];
---

<section class="section-padding relative">
  <div class="container px-6">
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-display text-center mb-16 reveal reveal-up">
      Simple, <span class="italic text-gradient">transparent</span> pricing.
    </h2>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {plans.map((plan, i) => (
        <div class="reveal reveal-up" data-delay={String(i + 1)}>
          <div
            class:list={[
              'group relative h-full overflow-hidden rounded-lg border p-0 transition-all duration-300 bg-white',
              plan.featured
                ? 'border-primary/30 glow-sm shadow-md'
                : 'border-border shadow-sm hover:border-primary/20 hover:shadow-md',
            ]}
          >
            {/* Hover glow overlay — CSS only via group-hover */}
            {plan.featured && (
              <div class="absolute inset-0 bg-gradient-to-br from-[#eb336e]/10 to-[#9b274c]/10 opacity-10 transition-opacity duration-300 group-hover:opacity-30 pointer-events-none" />
            )}

            {plan.badge && (
              <span class="absolute top-4 right-4 inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold tracking-wide text-primary">
                {plan.badge}
              </span>
            )}

            <div class="p-6 pb-4">
              <h3 class="text-2xl font-display tracking-tight">{plan.name}</h3>
            </div>

            <div class="p-6 pt-0 space-y-6">
              {/* Waitlist pricing message */}
              <div>
                <p class="text-lg font-display font-medium text-gradient">Join Waitlist for Launch Pricing</p>
                <p class="text-sm text-muted-foreground mt-1">{plan.tagline}</p>
              </div>

              <ul class="space-y-3">
                {plan.features.map((feature, j) => (
                  <li class="reveal reveal-left flex items-center gap-3" data-delay={String(Math.min(j + 2, 8))}>
                    <div class="w-5 h-5 rounded-full bg-[#eb336e]/10 flex items-center justify-center shrink-0">
                      <svg class="w-3 h-3 text-[#eb336e]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                    </div>
                    <span class="text-muted-foreground">{feature}</span>
                  </li>
                ))}
              </ul>

              <button
                type="button"
                class:list={[
                  'pricing-cta w-full inline-flex items-center justify-center rounded-md px-6 py-3 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2',
                  plan.featured
                    ? 'bg-gradient-to-r from-[#eb336e] to-[#9b274c] text-white shadow-sm hover:shadow-md hover:brightness-110'
                    : 'border border-border bg-white text-foreground hover:bg-secondary hover:text-foreground',
                ]}
              >
                Join Waitlist
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-muted-foreground mt-10 flex items-center justify-center gap-2 reveal reveal-up" data-delay="3">
      <svg class="w-4 h-4 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      </svg>
      Join the waitlist for exclusive launch pricing
    </p>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.pricing-cta').forEach((btn) => {
    btn.addEventListener('click', () => {
      const newsletter = document.getElementById('newsletter');
      if (newsletter) {
        newsletter.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
