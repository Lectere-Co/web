---
/**
 * SocialProof — compact persona circles showing who Lectere is built for.
 * Uses .reveal/.reveal-scale classes animated by Layout.astro IntersectionObserver.
 */
---

<section class="py-16 relative">
  <div class="container px-6 mx-auto max-w-4xl text-center">
    <h2 class="text-3xl md:text-4xl font-display mb-12 reveal">
      Built for people left behind by digital transformation
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 justify-items-center">
      <!-- Small Business Owners -->
      <div class="flex flex-col items-center gap-3 reveal reveal-scale" data-delay="1">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#eb336e] to-[#9b274c] flex items-center justify-center shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            <rect width="20" height="14" x="2" y="6" rx="2"/>
          </svg>
        </div>
        <span class="text-sm text-muted-foreground font-medium">Small Business Owners</span>
      </div>

      <!-- Older Adults -->
      <div class="flex flex-col items-center gap-3 reveal reveal-scale" data-delay="2">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#eb336e] to-[#9b274c] flex items-center justify-center shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
          </svg>
        </div>
        <span class="text-sm text-muted-foreground font-medium">Older Adults</span>
      </div>

      <!-- Career Changers -->
      <div class="flex flex-col items-center gap-3 reveal reveal-scale" data-delay="3">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#eb336e] to-[#9b274c] flex items-center justify-center shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/>
            <path d="M21 3v5h-5"/>
          </svg>
        </div>
        <span class="text-sm text-muted-foreground font-medium">Career Changers</span>
      </div>

      <!-- Students -->
      <div class="flex flex-col items-center gap-3 reveal reveal-scale" data-delay="4">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#eb336e] to-[#9b274c] flex items-center justify-center shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/>
            <path d="M22 10v6"/>
            <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/>
          </svg>
        </div>
        <span class="text-sm text-muted-foreground font-medium">Students</span>
      </div>
    </div>
  </div>
</section>
