<section class="relative py-24 md:py-32 overflow-hidden">
  <div class="absolute top-0 left-0 w-[500px] h-[500px] rounded-full bg-[#eb336e]/5 blur-[120px] -translate-y-1/2"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="reveal reveal-up text-center max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#eb336e]/10 border border-[#eb336e]/20 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#eb336e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
        <span class="text-sm font-medium text-[#eb336e]">Solutions</span>
      </div>

      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold text-foreground mb-6">
        Built for those <span class="text-gradient">left behind</span>
