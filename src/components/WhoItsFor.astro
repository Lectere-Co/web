---
// WhoItsFor.astro — Static component with CSS reveal animations + mobile horizontal scroll
---

<section class="section-padding relative bg-secondary/50">
  <div class="container px-6 relative">
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-display text-center mb-16 reveal reveal-up">
      Fighting <span class="text-gradient">digital displacement</span>.
    </h2>

    <div class="horizontal-scroll gap-4 pl-6 md:pl-0 md:grid md:grid-cols-2 lg:grid-cols-4 md:gap-6 lg:gap-8 md:overflow-visible max-w-6xl mx-auto">
      <!-- Small Business Owners -->
      <div class="scroll-item w-[280px] md:w-auto reveal reveal-left" data-delay="1">
        <div class="persona-card h-full rounded-xl border border-border hover:border-primary/30 hover:-translate-y-3 transition-all duration-500 group relative overflow-hidden shadow-sm hover:shadow-md bg-white">
          <div class="p-8 text-center relative z-10">
            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[#eb336e] to-[#9b274c] flex items-center justify-center mx-auto mb-6 shadow-lg persona-icon transition-all duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-3">Small Business Owners</h3>
            <p class="text-muted-foreground leading-relaxed">Navigate essential business software without expensive training or IT support</p>
          </div>
          <div class="persona-glow absolute inset-0 bg-gradient-to-br from-[#eb336e] to-[#9b274c] opacity-0 transition-opacity duration-500"></div>
        </div>
      </div>

      <!-- Older Adults -->
      <div class="scroll-item w-[280px] md:w-auto reveal reveal-right" data-delay="2">
        <div class="persona-card h-full rounded-xl border border-border hover:border-primary/30 hover:-translate-y-3 transition-all duration-500 group relative overflow-hidden shadow-sm hover:shadow-md bg-white">
          <div class="p-8 text-center relative z-10">
            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[#9b274c] to-[#eb336e] flex items-center justify-center mx-auto mb-6 shadow-lg persona-icon transition-all duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-3">Older Adults</h3>
            <p class="text-muted-foreground leading-relaxed">Access essential digital services—banking, healthcare, government—with confidence</p>
          </div>
          <div class="persona-glow absolute inset-0 bg-gradient-to-br from-[#9b274c] to-[#eb336e] opacity-0 transition-opacity duration-500"></div>
        </div>
      </div>

      <!-- Career Changers -->
      <div class="scroll-item w-[280px] md:w-auto reveal reveal-left" data-delay="3">
        <div class="persona-card h-full rounded-xl border border-border hover:border-primary/30 hover:-translate-y-3 transition-all duration-500 group relative overflow-hidden shadow-sm hover:shadow-md bg-white">
          <div class="p-8 text-center relative z-10">
            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[#c43278] to-[#832558] flex items-center justify-center mx-auto mb-6 shadow-lg persona-icon transition-all duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
                <path d="M21 3v5h-5"></path>
                <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
                <path d="M8 16H3v5"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-3">Career Changers</h3>
            <p class="text-muted-foreground leading-relaxed">Learn new industry software quickly when transitioning to a new field</p>
          </div>
          <div class="persona-glow absolute inset-0 bg-gradient-to-br from-[#c43278] to-[#832558] opacity-0 transition-opacity duration-500"></div>
        </div>
      </div>

      <!-- Students -->
      <div class="scroll-item w-[280px] md:w-auto reveal reveal-right" data-delay="4">
        <div class="persona-card h-full rounded-xl border border-border hover:border-primary/30 hover:-translate-y-3 transition-all duration-500 group relative overflow-hidden shadow-sm hover:shadow-md bg-white">
          <div class="p-8 text-center relative z-10">
            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[#832558] to-[#6e1f3d] flex items-center justify-center mx-auto mb-6 shadow-lg persona-icon transition-all duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"></path>
                <path d="M22 10v6"></path>
                <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-semibold mb-3">Students</h3>
            <p class="text-muted-foreground leading-relaxed">Master professional software at under-resourced schools without expert guidance</p>
          </div>
          <div class="persona-glow absolute inset-0 bg-gradient-to-br from-[#832558] to-[#6e1f3d] opacity-0 transition-opacity duration-500"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .persona-card:hover .persona-glow {
    opacity: 0.05;
  }
  .persona-card:hover .persona-icon {
    transform: scale(1.1) rotate(3deg);
  }
</style>
